# ===== Ollama (LLM local) =====
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=120

# ===== Milvus (vía Docker, ver docker-compose.yml) =====
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=datagov_docs
EMBED_DIM=768

# ===== RAG =====
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RAG_TOP_K=4

# ===== Rutas de datos (fuente canónica: paquete datagov_agent_dataset/) =====
DATA_DIR=data
RAW_DIR=datagov_agent_dataset/data/raw
PROCESSED_DIR=data/processed
SYNTHETIC_DIR=data/synthetic
DOCUMENTS_DIR=datagov_agent_dataset/data/documents
REPORTS_DIR=data/processed/reports
DATA_DICTIONARY=datagov_agent_dataset/data/raw/diccionario_datos.csv
EXPECTED_OUTPUTS=datagov_agent_dataset/data/expected_outputs/known_issues_expected.json

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
